<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="hun.mesh.carwithautoplay">

    <application
        android:label="CarWithAutoPlay">

        <!-- LSPosed 模块声明 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true"/>
        <meta-data
            android:name="xposeddescription"
            android:value="QQ音乐上车续播的垃圾逻辑修改"/>
        <meta-data
            android:name="xposedminversion"
            android:value="93"/>
        <!-- LSPosed scope 限制：只注入 carwith -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/lsposed_scopes"/>
    </application>
</manifest>